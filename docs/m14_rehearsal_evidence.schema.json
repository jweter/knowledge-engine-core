{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/knowledge-engine/m14_rehearsal_evidence.schema.json",
  "title": "Knowledge Engine M14 Controlled Rehearsal Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "decision",
    "execution_state",
    "repository_commit_sha",
    "corpus",
    "environment",
    "preflight",
    "fresh_import",
    "linked_resume",
    "artifact_hygiene",
    "unknowns"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "decision": {
      "enum": ["PROCEED", "HOLD", "STOPPED"]
    },
    "execution_state": {
      "enum": ["not_started", "completed", "stopped"]
    },
    "repository_commit_sha": {
      "$ref": "#/$defs/sha256_hex"
    },
    "corpus": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "corpus_id",
        "manifest_version",
        "corpus_json_sha256",
        "sources_csv_sha256",
        "accepted_source_rows",
        "unique_source_ids",
        "included_full_text_rows",
        "present_declared_files",
        "licensed_or_authorized_rows"
      ],
      "properties": {
        "corpus_id": {"type": "string", "minLength": 1},
        "manifest_version": {"type": "integer", "minimum": 1},
        "corpus_json_sha256": {"$ref": "#/$defs/sha256_hex"},
        "sources_csv_sha256": {"$ref": "#/$defs/sha256_hex"},
        "accepted_source_rows": {"type": "integer", "minimum": 0},
        "unique_source_ids": {"type": "integer", "minimum": 0},
        "included_full_text_rows": {"type": "integer", "minimum": 0},
        "present_declared_files": {"type": "integer", "minimum": 0},
        "licensed_or_authorized_rows": {"type": "integer", "minimum": 0}
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "os_family",
        "os_major_version",
        "architecture",
        "python_version",
        "storage_class",
        "logical_cpu_count",
        "memory_band"
      ],
      "properties": {
        "os_family": {"type": "string", "minLength": 1},
        "os_major_version": {"type": "string", "minLength": 1},
        "architecture": {"type": "string", "minLength": 1},
        "python_version": {"type": "string", "minLength": 1},
        "storage_class": {
          "enum": ["local_ssd", "local_hdd", "network_filesystem", "unknown"]
        },
        "logical_cpu_count": {"type": ["integer", "null"], "minimum": 1},
        "memory_band": {
          "enum": ["<8 GB", "8-16 GB", "16-32 GB", ">32 GB", "unknown"]
        }
      }
    },
    "preflight": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "quality_suite_passed",
        "manifest_validation_passed",
        "file_readiness_passed",
        "duplicate_source_ids",
        "unsafe_paths",
        "database_bytes_before"
      ],
      "properties": {
        "quality_suite_passed": {"type": "boolean"},
        "manifest_validation_passed": {"type": "boolean"},
        "file_readiness_passed": {"type": "boolean"},
        "duplicate_source_ids": {"type": "integer", "minimum": 0},
        "unsafe_paths": {"type": "integer", "minimum": 0},
        "database_bytes_before": {"type": ["integer", "null"], "minimum": 0}
      }
    },
    "fresh_import": {
      "$ref": "#/$defs/run_evidence"
    },
    "linked_resume": {
      "allOf": [
        {"$ref": "#/$defs/run_evidence"},
        {
          "type": "object",
          "required": [
            "parent_import_run_id",
            "paper_rows_before",
            "paper_rows_after",
            "paper_text_rows_before",
            "paper_text_rows_after",
            "fts_rows_before",
            "fts_rows_after",
            "lineage_reconciled_items",
            "idempotent"
          ],
          "properties": {
            "parent_import_run_id": {"type": ["string", "null"]},
            "paper_rows_before": {"type": ["integer", "null"], "minimum": 0},
            "paper_rows_after": {"type": ["integer", "null"], "minimum": 0},
            "paper_text_rows_before": {"type": ["integer", "null"], "minimum": 0},
            "paper_text_rows_after": {"type": ["integer", "null"], "minimum": 0},
            "fts_rows_before": {"type": ["integer", "null"], "minimum": 0},
            "fts_rows_after": {"type": ["integer", "null"], "minimum": 0},
            "lineage_reconciled_items": {"type": ["integer", "null"], "minimum": 0},
            "idempotent": {"type": ["boolean", "null"]}
          }
        }
      ]
    },
    "rates": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": [
        "failure_numerator",
        "failure_rate",
        "issue_numerator",
        "issue_rate",
        "warning_numerator",
        "warning_rate",
        "review_required_numerator",
        "review_required_rate"
      ],
      "properties": {
        "failure_numerator": {"type": "integer", "minimum": 0},
        "failure_rate": {"type": "number", "minimum": 0, "maximum": 1},
        "issue_numerator": {"type": "integer", "minimum": 0},
        "issue_rate": {"type": "number", "minimum": 0, "maximum": 1},
        "warning_numerator": {"type": "integer", "minimum": 0},
        "warning_rate": {"type": "number", "minimum": 0, "maximum": 1},
        "review_required_numerator": {"type": "integer", "minimum": 0},
        "review_required_rate": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "artifact_hygiene": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pdfs_committed",
        "databases_committed",
        "private_paths_present",
        "raw_exception_text_present",
        "temporary_artifacts_present",
        "git_diff_reviewed",
        "exact_head_quality_passed"
      ],
      "properties": {
        "pdfs_committed": {"type": "boolean"},
        "databases_committed": {"type": "boolean"},
        "private_paths_present": {"type": "boolean"},
        "raw_exception_text_present": {"type": "boolean"},
        "temporary_artifacts_present": {"type": "boolean"},
        "git_diff_reviewed": {"type": "boolean"},
        "exact_head_quality_passed": {"type": "boolean"}
      }
    },
    "stop_condition": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["code", "summary"],
      "properties": {
        "code": {
          "enum": [
            "entry_gate_failed",
            "unexpected_systemic_exception",
            "count_reconciliation_failed",
            "resume_idempotency_failed",
            "lineage_reconciliation_failed",
            "measurement_unavailable",
            "artifact_hygiene_failed",
            "input_changed",
            "other"
          ]
        },
        "summary": {"type": "string", "minLength": 1}
      }
    },
    "unknowns": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    }
  },
  "$defs": {
    "sha256_hex": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "run_evidence": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "import_run_id",
        "run_mode",
        "run_status",
        "review_status",
        "started_at_utc",
        "completed_at_utc",
        "elapsed_seconds",
        "source_rows",
        "persisted_items",
        "imported",
        "failed",
        "skipped",
        "needs_review",
        "warning_count",
        "issue_count",
        "issue_code_counts",
        "database_bytes_after",
        "database_growth_bytes",
        "counts_reconciled"
      ],
      "properties": {
        "import_run_id": {"type": ["string", "null"]},
        "run_mode": {"enum": ["fresh", "resume", "retry_failed", null]},
        "run_status": {"type": ["string", "null"]},
        "review_status": {"type": ["string", "null"]},
        "started_at_utc": {"type": ["string", "null"], "format": "date-time"},
        "completed_at_utc": {"type": ["string", "null"], "format": "date-time"},
        "elapsed_seconds": {"type": ["number", "null"], "minimum": 0},
        "source_rows": {"type": ["integer", "null"], "minimum": 0},
        "persisted_items": {"type": ["integer", "null"], "minimum": 0},
        "imported": {"type": ["integer", "null"], "minimum": 0},
        "failed": {"type": ["integer", "null"], "minimum": 0},
        "skipped": {"type": ["integer", "null"], "minimum": 0},
        "needs_review": {"type": ["integer", "null"], "minimum": 0},
        "warning_count": {"type": ["integer", "null"], "minimum": 0},
        "issue_count": {"type": ["integer", "null"], "minimum": 0},
        "issue_code_counts": {
          "type": "object",
          "additionalProperties": {"type": "integer", "minimum": 0}
        },
        "database_bytes_after": {"type": ["integer", "null"], "minimum": 0},
        "database_growth_bytes": {"type": ["integer", "null"]},
        "counts_reconciled": {"type": ["boolean", "null"]}
      }
    }
  }
}